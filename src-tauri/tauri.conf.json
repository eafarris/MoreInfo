{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MoreInfo",
  "version": "0.1.0",
  "identifier": "com.moreinfo.dev",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MoreInfo",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 400,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
